{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Autoteur",
  "version": "0.1.0",
  "identifier": "com.autoteur.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Autoteur",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "backgroundColor": "#101014"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": false
  }
}
